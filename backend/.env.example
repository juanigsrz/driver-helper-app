# --- Services ---
OSRM_URL=http://localhost:5000
NOMINATIM_URL=http://localhost:7070

# --- Driver cost model (ARS / km) ---
# All-in per km driven: fuel + maintenance + tires + depreciation.
COST_PER_KM=400

# Platform commission (Uber/Cabify cut). 0.25 = 25%.
PLATFORM_COMMISSION=0.25

# --- Verdict thresholds (profit AFTER commission AFTER cost) ---
MIN_ARS_PER_KM=600
MIN_ARS_PER_HR=8000
MAX_DEADHEAD_RATIO=0.40

# --- Auth between Android app and backend ---
SHARED_SECRET=change-me-please

# --- Server ---
BIND_HOST=127.0.0.1
BIND_PORT=8000
